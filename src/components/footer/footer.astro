	<div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between text-amber-50">
		<p class="text-xl sm:text-2xl font-bold tracking-tight">Mixx<span class="text-amber-200">Fit</span></p>
		<p class="font-semibold text-amber-100/90">{currentYear}</p>
	</div>
</footer>
