
---
const { title, subtitle, icon, cardColor, iconColor, positionClasses, animDelay = "0s" } = Astro.props;
---

<div
    class={`hidden xl:block absolute ${positionClasses} ${cardColor} backdrop-blur-sm shadow-lg font-semibold text-gray-600 rounded-lg p-4 stat-card`}
    style={`animation-delay: ${animDelay};`}
>
    <div class="flex gap-4 items-center">
        <i class={`${icon} ${iconColor} text-xl`}></i>

        <div class="flex flex-col">
            <p class="text-sm">{title}</p>
            <p class="text-slate-800">{subtitle}</p>
        </div>
    </div>
</div>

<style>
    @keyframes floatCard {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-6px); }
    }

    .stat-card {
        animation: floatCard 4s ease-in-out infinite;
    }
</style>
